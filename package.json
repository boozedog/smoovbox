{
  "name": "smoovwrapper",
  "version": "1.0.0",
  "description": "Local proxy server using Claude Max subscription to expose OpenAI-compatible and Anthropic-compatible API endpoints",
  "type": "module",
  "scripts": {
    "start": "bun run bin/smoovwrapper.ts",
    "dev": "LOG_LEVEL=debug bun --watch run bin/smoovwrapper.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.25",
    "hono": "^4.11.4",
    "just-bash": "^2.13.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/bun": "^1.2.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.2"
  },
  "license": "MIT",
  "smoovwrapper": {
    "passthrough": ["st", "git", "gh", "fd", "rg"]
  }
}
